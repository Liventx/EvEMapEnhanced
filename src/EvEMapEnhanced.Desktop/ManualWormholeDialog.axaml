<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EvEMapEnhanced.Desktop.ManualWormholeDialog"
        Title="Ручная червоточина"
        Icon="avares://EvEMapEnhanced.Desktop/Assets/app-icon.png"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" Margin="16" RowSpacing="10">
    <TextBlock Name="SystemLabel" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="Выходная система:" />
    <AutoCompleteBox Grid.Row="2" Name="ExitSystemBox" PlaceholderText="Название системы" MinHeight="28" />
    <TextBlock Grid.Row="3" Name="ValidationText" Foreground="IndianRed" FontSize="11" IsVisible="False" />
    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Name="CancelButton" Content="Отмена" MinWidth="90" Click="OnCancelClick" />
      <Button Name="OkButton" Content="Добавить" MinWidth="90" Click="OnOkClick" IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
