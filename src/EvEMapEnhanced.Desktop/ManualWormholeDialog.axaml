<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EvEMapEnhanced.Desktop.ManualWormholeDialog"
        Title="Ручная червоточина"
        Icon="avares://EvEMapEnhanced.Desktop/Assets/app-icon.png"
        Width="420" Height="220"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16" RowSpacing="10">
    <TextBlock Name="SystemLabel" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="Выходная система (комментарий):" />
    <TextBox Grid.Row="2" Name="ExitCommentBox" PlaceholderText="Например: Jita, Thera, C2..." />
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Name="CancelButton" Content="Отмена" MinWidth="90" Click="OnCancelClick" />
      <Button Name="OkButton" Content="Добавить" MinWidth="90" Click="OnOkClick" IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
