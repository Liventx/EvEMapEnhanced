<Window xmlns="https://github.com/avaloniaui"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:local="clr-namespace:EvEMapEnhanced.Desktop"

        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="800"

        x:Class="EvEMapEnhanced.Desktop.MainWindow"

        Title="EvE Map Enhanced"

        Icon="avares://EvEMapEnhanced.Desktop/Assets/app-icon.png"

        Width="1300" Height="800">

  <DockPanel>



    <Menu DockPanel.Dock="Top">

      <MenuItem Header="Данные">

        <MenuItem Name="DownloadSdeMenuItem" Header="Скачать / обновить SDE" Click="OnDownloadSdeClick" />

        <MenuItem Header="Структуры..." Click="OnStructuresClick" />

      </MenuItem>

      <MenuItem Header="Аккаунт">

        <MenuItem Name="SignInMenuItem" Header="Войти в EVE Online" Click="OnSignInClick" />

        <MenuItem Name="RefreshSkillsMenuItem" Header="Обновить навыки" Click="OnRefreshSkillsClick" />

      </MenuItem>

      <MenuItem Header="Карта">

        <MenuItem Header="Режим отображения">

          <MenuItem Name="MapModeSchematicMenuItem" Header="Схема (Dotlan)" IsChecked="True" ToggleType="Radio"

                    Click="OnMapModeSchematicClick" />

          <MenuItem Name="MapModeStandardMenuItem" Header="Обычная" ToggleType="Radio"

                    Click="OnMapModeStandardClick" />

        </MenuItem>

        <MenuItem Header="Раскраска систем">

          <MenuItem Name="ColorNpcKillsMenuItem" Header="NPC Kills" IsChecked="True" ToggleType="Radio"

                    Click="OnPlateColorNpcKillsClick" />

          <MenuItem Name="ColorSecurityMenuItem" Header="Security status" ToggleType="Radio"

                    Click="OnPlateColorSecurityClick" />

        </MenuItem>

        <Separator />

        <MenuItem Header="Wormhole">
          <MenuItem Name="ShowWormholesMenuItem" Header="Включить отображение"
                    IsChecked="True" ToggleType="CheckBox" Click="OnShowWormholesToggled" />
        </MenuItem>

        <Separator />

        <MenuItem Header="zKillboard">
          <MenuItem Name="ZKillboardJumpRangeScopeMenuItem" Header="Jump range" IsChecked="True" ToggleType="Radio"
                    Click="OnZKillboardJumpRangeScopeClick" />
          <MenuItem Name="ZKillboardGlobalScopeMenuItem" Header="Глобальный (весь nullsec)" ToggleType="Radio"
                    Click="OnZKillboardGlobalScopeClick" />
          <Separator />
          <MenuItem Name="ZKillboardPoliteMenuItem" Header="Осторожно (~1 запрос/с)" IsChecked="True" ToggleType="Radio"
                    Click="OnZKillboardPoliteClick" />
          <MenuItem Name="ZKillboardFasterMenuItem" Header="Быстрее (2 параллельно, ~2/с)" ToggleType="Radio"
                    Click="OnZKillboardFasterClick" />
        </MenuItem>

        <Separator />

        <MenuItem Header="Настройки маршрута">
          <MenuItem Header="Тип маршрута">
            <MenuItem Name="JumpMethodCynoMenuItem" Header="Cyno" IsChecked="True" ToggleType="Radio"
                      Click="OnJumpMethodCynoClick" />
            <MenuItem Name="JumpMethodCovertCynoMenuItem" Header="Covert cyno (Black Ops)" ToggleType="Radio"
                      Click="OnJumpMethodCovertCynoClick" />
          </MenuItem>
          <Separator />
          <MenuItem Name="UseWormholesInRoutingMenuItem" Header="Использовать Wormhole"
                    IsChecked="True" ToggleType="CheckBox" Click="OnUseWormholesInRoutingToggled" />
          <MenuItem Name="UseZarzakhInRoutingMenuItem" Header="Использовать Zarzakh"
                    IsChecked="True" ToggleType="CheckBox" Click="OnUseZarzakhInRoutingToggled" />
        </MenuItem>

      </MenuItem>

      <MenuItem Header="Отладка" IsVisible="False">

        <MenuItem Name="DebugGridMenuItem" Header="Отладочная сетка (координаты регионов)"
                  ToggleType="CheckBox" Click="OnDebugGridToggled" />

        <MenuItem Name="RegionEditMenuItem" Header="Редактировать регионы (перетаскивание мышью)"
                  ToggleType="CheckBox" Click="OnRegionEditToggled" />

        <MenuItem Name="ExportRegionPositionsMenuItem" Header="Экспортировать координаты регионов..."
                  Click="OnExportRegionPositionsClick" />

      </MenuItem>

      <MenuItem Header="Помощь">
        <MenuItem Name="CheckForUpdatesMenuItem" Header="Проверка обновлений"
                  Click="OnCheckForUpdatesClick" />
        <MenuItem Header="О программе" Click="OnAboutClick" />
      </MenuItem>

    </Menu>



    <!-- Main view: map left, unified mini-map + route column right -->

    <Grid>

      <Grid RowDefinitions="Auto,*" Margin="4">

      <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1,1,1,0" Padding="4,2">

        <Border.Styles>
          <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
          <Style Selector="Button">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
          <Style Selector="CheckBox">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
          <Style Selector="ToggleButton">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
          <Style Selector="local|MultiSelectDropDown">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
          <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
          <Style Selector="Slider">
            <Setter Property="VerticalAlignment" Value="Center" />
          </Style>
        </Border.Styles>

        <WrapPanel ItemSpacing="10" LineSpacing="4" VerticalAlignment="Center">

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="Основной профиль:" FontSize="11" />
            <ComboBox Name="PilotCombo" MinWidth="120" MaxWidth="170" FontSize="11" SelectionChanged="OnPilotSelectionChanged" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="Тип корабля:" FontSize="11" />
            <ComboBox Name="JumpRangeClassCombo" MinWidth="120" MaxWidth="170" FontSize="11" SelectionChanged="OnJumpRangeClassChanged" />
            <CheckBox Name="JumpRangeOnlineCheck" Content="Онлайн" FontSize="11" Click="OnJumpRangeOnlineToggled" />
            <Button Name="CenterPilotButton" Padding="4,0" MinWidth="22" Click="OnCenterPilotClick"
                    ToolTip.Tip="Центрировать на основном профиле">
              <Path Width="12" Height="12" Stretch="Uniform"
                    Data="M7,0 L7,14 M0,7 L14,7 M7,3 A4,4 0 1 0 7,11 A4,4 0 1 0 7,3"
                    Stroke="Black" StrokeThickness="1.25" Fill="Transparent" />
            </Button>
            <CheckBox Name="FocusCheck" Content="Focus" FontSize="11" Click="OnFocusCheckToggled" />
            <ToggleButton Name="JumpRangeSimulationToggle" Content="Симуляция" FontSize="11"
                          ToolTip.Tip="Симуляция дальности прыжка"
                          Click="OnJumpRangeSimulationToggled" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="Профиль Cyno:" FontSize="11" />
            <local:MultiSelectDropDown Name="CynoProfileSelector" MinWidth="120" MaxWidth="170" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="Профиль SC:" FontSize="11" />
            <local:MultiSelectDropDown Name="ScProfileSelector" MinWidth="120" MaxWidth="170" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="Масштаб:" FontSize="11" />
            <Button Name="MapZoomOutButton" Content="−" FontSize="12" FontWeight="Bold"
                    MinWidth="22" Click="OnMapZoomOutClick"
                    ToolTip.Tip="Отдалить" />
            <Slider Name="MapZoomSlider" MinWidth="80" MaxWidth="140" Minimum="0" Maximum="100" Value="50"
                    ValueChanged="OnMapZoomSliderChanged"
                    ToolTip.Tip="Масштаб карты" />
            <Button Name="MapZoomInButton" Content="+" FontSize="12" FontWeight="Bold"
                    MinWidth="22" Click="OnMapZoomInClick"
                    ToolTip.Tip="Приблизить" />
            <TextBlock Name="MapZoomLevelText" Text="3.00" FontSize="11" FontFamily="Consolas,Courier New,monospace"
                       MinWidth="48" TextAlignment="Right"
                       ToolTip.Tip="Текущий масштаб (ZoomLevel)" />
          </StackPanel>

        </WrapPanel>

      </Border>



      <Grid Grid.Row="1" ColumnDefinitions="*,360">

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1,0,0,1" Margin="0,0,4,0">

          <local:MapControl Name="RouteMap" />

        </Border>



        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">

          <Grid RowDefinitions="Auto,Auto,*">

            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="8,6">

              <StackPanel Spacing="4">

                <TextBlock Text="Поиск системы" FontSize="11" FontWeight="SemiBold" />

                <AutoCompleteBox Name="SystemSearchBox" PlaceholderText="Название системы" FontSize="11" MinHeight="28"

                                 SelectionChanged="OnSystemSearchSelectionChanged"

                                 TextChanged="OnSystemSearchTextChanged"

                                 KeyDown="OnSystemSearchKeyDown" />

              </StackPanel>

            </Border>



            <Border Grid.Row="1" Name="JumpRangeMiniMapPanel" Height="360"

                    Background="White" BorderBrush="Gray" BorderThickness="0,0,0,1">

              <Grid RowDefinitions="Auto,*">

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6,4">

                  <StackPanel Spacing="2">

                    <TextBlock Name="JumpRangeMiniMapLabel" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"

                               Text="Дальность прыжка (Black Ops): выберите систему на карте" />

                    <TextBlock Name="PvpStatusText" FontSize="10" Foreground="#555" TextWrapping="Wrap"

                               Text="zKillboard: выберите систему для jump range" />

                  </StackPanel>

                </Border>

                <local:MapControl Grid.Row="1" Name="JumpRangeMiniMap" />

              </Grid>

            </Border>



            <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="8,6">

              <StackPanel Grid.Row="0" Spacing="4">

                <TextBlock Text="Маршрут от" FontSize="11" FontWeight="SemiBold" />

                <AutoCompleteBox Name="RouteFromBox" PlaceholderText="System (RMB on map)" FontSize="11" MinHeight="28" />



                <TextBlock Text="Маршрут до" FontSize="11" FontWeight="SemiBold" />

                <AutoCompleteBox Name="RouteToBox" PlaceholderText="System (RMB on map)" FontSize="11" MinHeight="28" />

                <Grid ColumnDefinitions="*,*,*">
                  <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,4,0">
                    <TextBlock Text="Тип корабля" FontSize="11" FontWeight="SemiBold" />
                    <ComboBox Name="ShipClassCombo" HorizontalAlignment="Stretch" FontSize="11"
                              SelectionChanged="OnRouteShipClassChanged" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,4,0">
                    <TextBlock Text="Приоритет" FontSize="11" FontWeight="SemiBold" />
                    <ComboBox Name="RoutePreferenceCombo" HorizontalAlignment="Stretch" FontSize="11" SelectedIndex="0">
                      <ComboBoxItem Content="Fastest" Tag="Shorter" />
                      <ComboBoxItem Content="Prefer high-sec" Tag="Safer" />
                      <ComboBoxItem Content="Prefer low/null" Tag="LessSecure" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="2">
                    <TextBlock Text="Тип маршрута" FontSize="11" FontWeight="SemiBold" />
                    <ComboBox Name="RouteModeCombo" HorizontalAlignment="Stretch" FontSize="11" SelectedIndex="2">
                      <ComboBoxItem Content="Gates only" />
                      <ComboBoxItem Content="Jump only" />
                      <ComboBoxItem Content="Hybrid" />
                    </ComboBox>
                  </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,Auto">
                  <Button Name="BuildRouteButton" Grid.Column="0" Content="Построить маршрут" Click="OnBuildRouteClick"
                          FontSize="11" Padding="8,6" MinHeight="32" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Center" VerticalAlignment="Stretch"
                          Margin="0,0,4,0" />
                  <Button Name="ClearRouteButton" Grid.Column="1" Click="OnClearRouteClick" MinWidth="32" MinHeight="32"
                          Padding="8,6" VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                          ToolTip.Tip="Сбросить маршрут">
                    <Path Width="12" Height="12" Stretch="Uniform"
                          Data="M2,2 L12,12 M12,2 L2,12"
                          Stroke="Black" StrokeThickness="1.25" />
                  </Button>
                </Grid>

              </StackPanel>

              <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,6,0,0">

                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                  <TextBlock Text="Маршрут" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Name="RouteSummaryText" Grid.Column="1" TextWrapping="Wrap" FontSize="10"
                             FontWeight="SemiBold" HorizontalAlignment="Right" TextAlignment="Right"
                             VerticalAlignment="Center" Margin="8,0,0,0" />
                </Grid>

                <ListBox Name="RouteStepsList" Grid.Row="1" FontSize="10"
                         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:RouteStepListItem">
                      <Border Padding="4,2" Background="{Binding RowBackground}">
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

              </Grid>

            </Grid>

          </Grid>

        </Border>

      </Grid>

      </Grid>

      <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="16" Spacing="6">
        <ProgressBar Name="SdeProgressBar" MinWidth="200" MaxWidth="420" Minimum="0" Maximum="1"
                     IsVisible="False" Height="14" />
        <local:BottomToast Name="DiagnosticToast" />
      </StackPanel>

    </Grid>

  </DockPanel>

</Window>

