<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EvEMapEnhanced.Desktop"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="800"
        x:Class="EvEMapEnhanced.Desktop.MainWindow"
        Title="EvE Map Enhanced"
        Width="1300" Height="800">
  <DockPanel>

    <!-- Toolbar: SDE status + download -->
    <Border DockPanel.Dock="Top" Padding="10" BorderThickness="0,0,0,1" BorderBrush="Gray">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="SDE:" VerticalAlignment="Center" FontWeight="Bold" />
        <TextBlock Name="SdeStatusText" Text="не загружен" VerticalAlignment="Center" />
        <Button Name="DownloadSdeButton" Content="Скачать / обновить SDE" Click="OnDownloadSdeClick" />
        <ProgressBar Name="SdeProgressBar" Width="200" Minimum="0" Maximum="1" IsVisible="False" />
      </StackPanel>
    </Border>

    <TabControl>

      <!-- ================= ROUTE TAB (GARPA-style: map left, controls right) ================= -->
      <TabItem Header="Маршрут">
        <Grid ColumnDefinitions="*,270" Margin="4">
          <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="0,0,4,0">
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1,1,1,0" Padding="6,4">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Режим карты:" VerticalAlignment="Center" FontSize="11" />
                <ComboBox Name="MapModeCombo" Width="180" FontSize="11" SelectedIndex="0" SelectionChanged="OnMapModeChanged">
                  <ComboBoxItem Content="Обычная" Tag="Standard" />
                  <ComboBoxItem Content="Схема (Dotlan)" Tag="Schematic" />
                </ComboBox>
              </StackPanel>
            </Border>
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
              <local:MapControl Name="RouteMap" />
            </Border>
          </Grid>

          <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4">
              <TextBlock Text="From" FontSize="11" FontWeight="SemiBold" />
              <AutoCompleteBox Name="RouteFromBox" PlaceholderText="System (RMB on map)" FontSize="11" MinHeight="28" />

              <TextBlock Text="To" FontSize="11" FontWeight="SemiBold" />
              <AutoCompleteBox Name="RouteToBox" PlaceholderText="System (RMB on map)" FontSize="11" MinHeight="28" />

              <TextBlock Text="Route mode" FontSize="11" FontWeight="SemiBold" />
              <ComboBox Name="RouteModeCombo" HorizontalAlignment="Stretch" FontSize="11" SelectedIndex="2">
                <ComboBoxItem Content="Gates only" />
                <ComboBoxItem Content="Jump only" />
                <ComboBoxItem Content="Hybrid" />
              </ComboBox>

              <TextBlock Text="Gate preference" FontSize="11" FontWeight="SemiBold" />
              <ComboBox Name="RoutePreferenceCombo" HorizontalAlignment="Stretch" FontSize="11" SelectedIndex="0">
                <ComboBoxItem Content="Fastest" Tag="Shorter" />
                <ComboBoxItem Content="Prefer high-sec" Tag="Safer" />
                <ComboBoxItem Content="Prefer low/null" Tag="LessSecure" />
              </ComboBox>

              <TextBlock Text="Ship class" FontSize="11" FontWeight="SemiBold" />
              <ComboBox Name="ShipClassCombo" HorizontalAlignment="Stretch" FontSize="11" SelectionChanged="OnShipClassChanged" />

              <TextBlock Text="Hull" FontSize="11" FontWeight="SemiBold" />
              <ComboBox Name="ShipHullCombo" HorizontalAlignment="Stretch" FontSize="11" />

              <TextBlock Text="Jump method" FontSize="11" FontWeight="SemiBold" />
              <ComboBox Name="JumpMethodCombo" HorizontalAlignment="Stretch" FontSize="11" SelectedIndex="0">
                <ComboBoxItem Content="Cyno" />
                <ComboBoxItem Content="Covert cyno (Black Ops)" />
              </ComboBox>

              <TextBlock Text="Pilot profile" FontSize="11" FontWeight="SemiBold" />
              <ComboBox Name="ProfileCombo" HorizontalAlignment="Stretch" FontSize="11" SelectionChanged="OnProfileSelectionChangedForRoute" />

              <CheckBox Name="AvoidLowSecCheck" Content="Avoid low-sec" FontSize="11" />
              <CheckBox Name="AvoidNullSecCheck" Content="Avoid null-sec" FontSize="11" />
              <CheckBox Name="AvoidActivityCheck" Content="Kill activity penalty" FontSize="11" />

              <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Name="BuildRouteButton" Content="Build route" Click="OnBuildRouteClick" FontSize="11" Padding="8,4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <Button Name="SaveRouteButton" Content="Save" Click="OnSaveRouteClick" FontSize="11" Padding="8,4" />
              </StackPanel>

              <TextBlock Text="Route" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,0" />
              <ListBox Name="RouteStepsList" MinHeight="180" MaxHeight="320" FontSize="10" />

              <TextBlock Name="RouteSummaryText" TextWrapping="Wrap" FontSize="10" FontWeight="SemiBold" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- ================= PILOT PROFILE TAB ================= -->
      <TabItem Header="Профиль пилота">
        <Grid ColumnDefinitions="320,*" Margin="10">
          <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,10,0">
            <TextBlock Text="Профиль:" />
            <ComboBox Name="ProfileEditorCombo" HorizontalAlignment="Stretch" SelectionChanged="OnProfileEditorSelectionChanged" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Новый" Click="OnNewProfileClick" />
              <Button Content="Сохранить" Click="OnSaveProfileClick" />
              <Button Content="Удалить" Click="OnDeleteProfileClick" />
            </StackPanel>

            <TextBlock Text="Имя профиля:" />
            <TextBox Name="ProfileNameBox" />

            <TextBlock Text="Jump Drive Calibration (дальность):" />
            <NumericUpDown Name="JdcUpDown" Minimum="0" Maximum="5" Value="0" ValueChanged="OnJdcChanged" />

            <TextBlock Text="Jump Fuel Conservation (топливо):" />
            <NumericUpDown Name="JfcUpDown" Minimum="0" Maximum="5" Value="0" />

            <TextBlock Text="Jump Freighters (топливо JF):" />
            <NumericUpDown Name="JfUpDown" Minimum="0" Maximum="5" Value="0" />

            <TextBlock Text="Capital Ships:" />
            <NumericUpDown Name="CapitalShipsUpDown" Minimum="0" Maximum="5" Value="0" />

            <TextBlock Text="Black Ops:" />
            <NumericUpDown Name="BlackOpsUpDown" Minimum="0" Maximum="5" Value="0" />

            <TextBlock Text="Jump Drive Economizer:" />
            <ComboBox Name="EconomizerCombo" HorizontalAlignment="Stretch" SelectedIndex="0">
              <ComboBoxItem Content="Нет" />
              <ComboBoxItem Content="Тип I (-4%)" />
              <ComboBoxItem Content="Тип II (-7%)" />
              <ComboBoxItem Content="Тип III (-10%)" />
            </ComboBox>

            <CheckBox Name="ProfileAvoidLowSecCheck" Content="Избегать low-sec" />
            <CheckBox Name="ProfileAvoidNullSecCheck" Content="Избегать null-sec" />
            <CheckBox Name="ProfileAvoidActivityCheck" Content="Учитывать активность килов" />

            <TextBlock Text="Избегаемые системы (через запятую, ID):" TextWrapping="Wrap" />
            <TextBox Name="AvoidSystemsBox" AcceptsReturn="False" />
          </StackPanel>

          <StackPanel Grid.Column="1" Margin="10,0,0,0">
            <TextBlock Text="Расчётная дальность прыжка для выбранных кораблей (при текущих навыках):" TextWrapping="Wrap" FontWeight="Bold" />
            <ListBox Name="ShipRangePreviewList" Height="500" />
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- ================= STRUCTURES TAB ================= -->
      <TabItem Header="Структуры">
        <Grid ColumnDefinitions="380,*" Margin="10">
          <StackPanel Grid.Column="0" Spacing="8" Margin="0,0,10,0">
            <TextBlock Text="Система:" />
            <AutoCompleteBox Name="StructureSystemBox" PlaceholderText="Название системы" />

            <TextBlock Text="Тип структуры:" />
            <ComboBox Name="StructureKindCombo" HorizontalAlignment="Stretch" SelectionChanged="OnStructureKindChanged" />

            <TextBlock Text="Название:" />
            <TextBox Name="StructureNameBox" />

            <TextBlock Text="Владелец (тег):" />
            <TextBox Name="StructureOwnerBox" />

            <TextBlock Text="Уровень доступа:" />
            <ComboBox Name="StructureAccessCombo" HorizontalAlignment="Stretch" SelectedIndex="0">
              <ComboBoxItem Content="Свой альянс" />
              <ComboBoxItem Content="Своя корпорация" />
              <ComboBoxItem Content="Публичный" />
              <ComboBoxItem Content="Чёрный список" />
            </ComboBox>

            <TextBlock Name="LinkedSystemLabel" Text="Связанная система (для Ansiblex/JB):" />
            <AutoCompleteBox Name="StructureLinkedSystemBox" PlaceholderText="Название системы" />

            <TextBlock Text="Стронций (часы, для Ansiblex):" />
            <NumericUpDown Name="StrontUpDown" Minimum="0" Maximum="500" Value="0" />

            <TextBlock Text="Заметки:" />
            <TextBox Name="StructureNotesBox" AcceptsReturn="True" Height="60" />

            <Button Name="AddStructureButton" Content="Добавить структуру" Click="OnAddStructureClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
            <Button Name="DeleteStructureButton" Content="Удалить выбранную" Click="OnDeleteStructureClick" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
          </StackPanel>

          <ListBox Name="StructuresList" Grid.Column="1" />
        </Grid>
      </TabItem>

      <!-- ================= STATS TAB ================= -->
      <TabItem Header="Статистика систем">
        <StackPanel Margin="10" Spacing="10" Width="500" HorizontalAlignment="Left">
          <TextBlock Text="Система:" />
          <AutoCompleteBox Name="StatsSystemBox" PlaceholderText="Название системы" />
          <Button Name="StatsQueryButton" Content="Запросить статистику (zKillboard)" Click="OnStatsQueryClick" />
          <TextBlock Name="StatsResultText" TextWrapping="Wrap" />
        </StackPanel>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
